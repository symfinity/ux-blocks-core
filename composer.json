{
    "name": "symfinity/ux-blocks-core",
    "description": "Symfinity UX Blocks Core — fourteen v0 Symfony UX Twig components with registry-aligned markup",
    "license": "MIT",
    "keywords": [
        "symfony-ux"
    ],
    "type": "symfony-bundle",
    "require": {
        "php": ">=8.2",
        "symfinity/ux-blocks": "@dev",
        "symfony/framework-bundle": "^7.4||^8.0",
        "symfony/twig-bundle": "^7.4||^8.0",
        "symfony/stimulus-bundle": "^2.0|^3.0",
        "symfony/ux-twig-component": "^2.0|^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfinity/ui-action": "@dev",
        "symfony/browser-kit": "^7.4||^8.0",
        "symfony/css-selector": "^7.4||^8.0",
        "symfony/yaml": "^7.4||^8.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ux-blocks",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ui-action",
            "options": { "symlink": true }
        }
    ],
    "autoload": {
        "psr-4": {
            "Symfinity\\UxBlocksCore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\UxBlocksCore\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "suggest": {
        "symfinity/ui-kernel": "SchemeSwitch enhanced mode (PATCH /_ui/theme/scheme) and Chameleon theme cookies"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "version": "1.0.0-dev",
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    }
}
