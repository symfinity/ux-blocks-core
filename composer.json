{
    "name": "symfinity/ux-blocks-core",
    "description": "Symfinity UX Blocks Core — atomic Symfony UX Twig components with registry-aligned markup and role CSS",
    "type": "symfony-bundle",
    "license": "MIT",
    "homepage": "https://github.com/symfinity/ux-blocks-core",
    "support": {
        "issues": "https://github.com/symfinity/ux-blocks-core/issues",
        "source": "https://github.com/symfinity/ux-blocks-core"
    },
    "authors": [
        {
            "name": "Symfinity",
            "email": "dev@symfinity.net",
            "homepage": "https://symfinity.net/"
        }
    ],
    "keywords": [
        "symfony",
        "symfony-bundle",
        "symfony-ux",
        "twig-components",
        "ux-blocks",
        "design-system",
        "ui-kernel"
    ],
    "require": {
        "php": ">=8.2",
        "symfinity/ui-action": "^0.1",
        "symfinity/ui-kernel": "^0.1",
        "symfinity/ux-blocks": "^0.1",
        "symfony/asset-mapper": "^7.4||^8.0",
        "symfony/browser-kit": "^7.4||^8.0",
        "symfony/config": "^7.4||^8.0",
        "symfony/css-selector": "^7.4||^8.0",
        "symfony/dependency-injection": "^7.4||^8.0",
        "symfony/form": "^7.4||^8.0",
        "symfony/framework-bundle": "^7.4||^8.0",
        "symfony/http-foundation": "^7.4||^8.0",
        "symfony/http-kernel": "^7.4||^8.0",
        "symfony/stimulus-bundle": "^2.0|^3.0",
        "symfony/twig-bundle": "^7.4||^8.0",
        "symfony/ux-twig-component": "^2.0|^3.0",
        "symfony/validator": "^7.4||^8.0",
        "symfony/yaml": "^7.4||^8.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ui-kernel",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ui-action",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ux-blocks",
            "options": { "symlink": true }
        }
    ],
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Symfinity\\UxBlocksCore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\UxBlocksCore\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "suggest": {
        "symfinity/ui-kernel": "Chameleon theme cookies and theme shell integration",
        "symfony/ux-icons": "Icon set for roles that use ux:icon (optional per app)"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "symfony": {
            "require": "^7.4||^8.0"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
