<!DOCTYPE html>
<html lang="en" data-theme="{{ ui_kernel_active_theme_id() }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>UX Blocks Core — variant matrix</title>
    {{ ui_kernel_theme_boot_script()|raw }}
    {{ ui_kernel_css()|raw }}
    <style id="ux-blocks-core-css">{{ ux_blocks_core_stylesheet()|raw }}</style>
    <style>
        body { margin: 0; background: var(--ui-color-surface); color: var(--ui-color-text); }
        .ux-catalog-page { padding: var(--ui-space-lg); font-family: var(--ui-font-family-sans); max-width: 80rem; margin-inline: auto; }
        .ux-catalog-lede { margin-block-end: var(--ui-space-xl); color: var(--ui-color-text-muted); max-width: 48rem; }
        .ux-catalog-role { margin-block-end: var(--ui-space-2xl); padding-block-end: var(--ui-space-xl); border-block-end: 1px solid var(--ui-color-border-subtle, #e5e7eb); }
        .ux-catalog-role h2 { margin-block-end: var(--ui-space-md); }
        .ux-catalog-section { margin-block-end: var(--ui-space-lg); }
        .ux-catalog-section h3 { margin-block-end: var(--ui-space-sm); font-size: 1rem; color: var(--ui-color-text-muted); }
        .ux-catalog-row, .ux-catalog-stack { display: flex; flex-wrap: wrap; gap: var(--ui-space-sm); align-items: center; }
        .ux-catalog-stack { flex-direction: column; align-items: flex-start; }
        .ux-catalog-item { display: block; }
        .ux-catalog-item:has(figcaption) { display: grid; gap: var(--ui-space-xs); }
        .ux-catalog-item figcaption { font-size: 0.75rem; color: var(--ui-color-text-muted); }
        .ux-catalog-item [data-ui-role="flash"] { width: 100%; max-width: min(28rem, 100%); }
        /* Layout atoms use width:100% on the role root — figures need a definite width (avoid 0px collapse in flex catalog chrome). */
        .ux-catalog-item:has([data-ui-role="stack"]),
        .ux-catalog-item:has([data-ui-role="grid"]),
        .ux-catalog-item:has([data-ui-role="list"]),
        .ux-catalog-item:has([data-ui-role="aspect-ratio"]) {
            flex: 1 1 14rem;
            min-width: 14rem;
            max-width: min(48rem, 100%);
            box-sizing: border-box;
        }
        .ux-catalog-stack .ux-catalog-item:has([data-ui-role="stack"]),
        .ux-catalog-stack .ux-catalog-item:has([data-ui-role="grid"]),
        .ux-catalog-stack .ux-catalog-item:has([data-ui-role="list"]),
        .ux-catalog-stack .ux-catalog-item:has([data-ui-role="aspect-ratio"]) {
            width: 100%;
        }
        #role-stack-direction .ux-catalog-item:has([data-ui-role="stack"]) {
            flex: 1 1 48rem;
            min-width: min(100%, 48rem);
        }
        .ux-catalog-size-table { border-collapse: collapse; width: 100%; max-width: 72rem; }
        .ux-catalog-size-table th, .ux-catalog-size-table td { padding: var(--ui-space-sm); text-align: start; vertical-align: middle; }
        .ux-catalog-size-table th[scope="row"] { font-weight: 600; white-space: nowrap; }
    </style>
</head>
<body>
    <main class="ux-catalog-page">
        <h1>UX Blocks Core — variant matrix</h1>
        <p class="ux-catalog-lede">
            Greenfield install smoke — every shipped core role from
            <code>config/component-examples/*.yaml</code> on one page.
        </p>

        {% include '@UxBlocksCore/catalog/_manifest_matrix.html.twig' %}
    </main>
</body>
</html>
