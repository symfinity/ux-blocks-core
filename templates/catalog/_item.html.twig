{% set show_label = show_label|default(true) %}
{# Slotted components carry their own copy — figcaption duplicates it (Badge, Flash, …). #}
{% set show_figcaption = show_label and not item.has_slot %}

{% if item.render_partial %}
    <figure class="ux-catalog-item" data-variant="{{ item.variant }}">
        {% if show_figcaption %}<figcaption>{{ item.label }}</figcaption>{% endif %}
        {% include item.render_partial with {
            role: manifest.role,
            twig_name: manifest.twig_name,
            item: item,
            manifest: manifest,
        } only %}
    </figure>
{% else %}
    <figure class="ux-catalog-item" data-variant="{{ item.variant }}">
        {% if show_figcaption %}<figcaption>{{ item.label }}</figcaption>{% endif %}
        {% include '@UxBlocksCore/catalog/_render_component.html.twig' with {
            twig_name: manifest.twig_name,
            props: item.props,
            has_slot: item.has_slot,
            slot_text: item.slot_text,
        } only %}
    </figure>
{% endif %}
