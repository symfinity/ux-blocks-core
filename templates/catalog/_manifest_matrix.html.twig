{% for manifest in manifests %}
<section
    class="ux-catalog-role"
    id="role-{{ manifest.role }}"
    data-catalog-role="{{ manifest.role }}"
>
    <h2>{{ manifest.twig_name }}</h2>

    {% for section in manifest.sections %}
        {% include '@UxBlocksCore/catalog/_section.html.twig' with {
            section: section,
            manifest: manifest,
        } only %}
    {% endfor %}
</section>
{% endfor %}
