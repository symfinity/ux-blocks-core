{# Shared v0 role gallery — optional `copy` and `table_rows` for themed showcases #}
{% set copy = copy|default({}) %}
{% set table_rows = table_rows|default([
    {name: 'Alpha', value: '1'},
    {name: 'Beta', value: '2'},
]) %}
{% set button_variants = ['default', 'secondary', 'tertiary', 'destructive', 'success', 'info', 'warning', 'outline', 'ghost', 'link'] %}
{% set button_sizes = ['sm', 'default', 'lg'] %}
{% set alert_variants = ['info', 'success', 'warning', 'destructive'] %}
{% set variant_labels = {
    default: 'Primary',
    secondary: 'Secondary',
    tertiary: 'Tertiary',
    destructive: 'Danger',
    success: 'Success',
    outline: 'Outline',
    ghost: 'Ghost',
    link: 'Link',
    info: 'Info',
    warning: 'Warning',
} %}

<section class="ux-blocks-catalog-section" id="role-button" data-catalog-role="button">
    <h2>Button</h2>

    <h3>Variants</h3>
    <div data-ui-role="grid" data-ui-columns="4">
        {% for variant in button_variants %}
            <twig:Button variant="{{ variant }}">{{ variant_labels[variant] }}</twig:Button>
        {% endfor %}
    </div>

    <h3>Sizes (primary)</h3>
    <div data-ui-role="grid" data-ui-columns="3">
        {% for size in button_sizes %}
            <twig:Button size="{{ size }}">{{ size|title }}</twig:Button>
        {% endfor %}
    </div>

    <h3>Variants × sizes</h3>
    <div data-ui-role="grid" data-ui-columns="3">
        {% for variant in button_variants %}
            {% for size in button_sizes %}
                <twig:Button variant="{{ variant }}" size="{{ size }}">{{ variant_labels[variant] }} / {{ size }}</twig:Button>
            {% endfor %}
        {% endfor %}
    </div>

    <h3>Disabled</h3>
    <div data-ui-role="grid" data-ui-columns="4">
        {% for variant in button_variants %}
            <twig:Button variant="{{ variant }}" disabled>{{ variant_labels[variant] }}</twig:Button>
        {% endfor %}
    </div>

    <h3>As link</h3>
    <div data-ui-role="grid" data-ui-columns="4">
        {% for variant in button_variants %}
            <twig:Button as="a" href="#role-button" variant="{{ variant }}">{{ variant_labels[variant] }}</twig:Button>
        {% endfor %}
    </div>

    <h3>Block (full width)</h3>
    <p>Pass <code>block</code> on the Twig component — emits <code>data-ui-layout="block"</code> (Bootstrap-style block button, Symfinity-owned attribute).</p>
    <div data-ui-role="stack" data-ui-gap="sm">
        {% for variant in button_variants %}
            <twig:Button variant="{{ variant }}" block>{{ variant_labels[variant] }} — block</twig:Button>
        {% endfor %}
    </div>
</section>

<section class="ux-blocks-catalog-section" id="role-separator" data-catalog-role="separator">
    <h2>Separator</h2>
    <p>Horizontal</p>
    <twig:Separator />
    <p>Vertical</p>
    <div style="display:flex;align-items:stretch;min-height:3rem;">
        <span>Left</span>
        <twig:Separator orientation="vertical" />
        <span>Right</span>
    </div>
</section>

<section class="ux-blocks-catalog-section" id="role-typography" data-catalog-role="typography">
    <h2>Typography</h2>
    <twig:Typography>
        <twig:Typography:H1>{{ copy.typography_h1|default('Heading One') }}</twig:Typography:H1>
        <twig:Typography:P>{{ copy.typography_p|default('Paragraph text.') }}</twig:Typography:P>
    </twig:Typography>
</section>

<section class="ux-blocks-catalog-section" id="role-empty" data-catalog-role="empty">
    <h2>Empty</h2>
    <twig:Empty>
        <twig:Empty:Media>{{ copy.empty_media|default('Media') }}</twig:Empty:Media>
        <twig:Empty:Header>
            <twig:Empty:Title>{{ copy.empty_title|default('No results') }}</twig:Empty:Title>
            <twig:Empty:Description>{{ copy.empty_description|default('Try adjusting your filters.') }}</twig:Empty:Description>
        </twig:Empty:Header>
    </twig:Empty>
</section>

<section class="ux-blocks-catalog-section" id="role-label" data-catalog-role="label">
    <h2>Label</h2>
    <twig:Label for="demo-input">{{ copy.label|default('Email') }}</twig:Label>
</section>

<section class="ux-blocks-catalog-section" id="role-input" data-catalog-role="input">
    <h2>Input</h2>
    <h3>Default</h3>
    <twig:Input id="demo-input" name="email" placeholder="{{ copy.input_placeholder|default('you@example.com') }}" />
    <h3>Disabled</h3>
    <twig:Input id="demo-input-disabled" name="email_disabled" disabled value="Disabled" />
    <h3>Invalid</h3>
    <twig:Input id="demo-input-invalid" name="email_invalid" invalid value="invalid@example.com" />
</section>

<section class="ux-blocks-catalog-section" id="role-textarea" data-catalog-role="textarea">
    <h2>Textarea</h2>
    <h3>Default</h3>
    <twig:Textarea name="notes" placeholder="{{ copy.textarea_placeholder|default('Notes') }}"></twig:Textarea>
    <h3>Disabled</h3>
    <twig:Textarea name="notes_disabled" disabled>Disabled content</twig:Textarea>
    <h3>Invalid</h3>
    <twig:Textarea name="notes_invalid" invalid>Invalid content</twig:Textarea>
</section>

<section class="ux-blocks-catalog-section" id="role-select" data-catalog-role="select">
    <h2>Select</h2>
    <h3>Default</h3>
    <twig:Select name="choice">
        <option value="a">{{ copy.select_a|default('Option A') }}</option>
        <option value="b">{{ copy.select_b|default('Option B') }}</option>
    </twig:Select>
    <h3>Disabled</h3>
    <twig:Select name="choice_disabled" disabled>
        <option value="a">{{ copy.select_a|default('Option A') }}</option>
    </twig:Select>
</section>

<section class="ux-blocks-catalog-section" id="role-checkbox" data-catalog-role="checkbox">
    <h2>Checkbox</h2>
    <div data-ui-role="grid" data-ui-columns="3">
        <twig:Label for="demo-check-default">Default</twig:Label>
        <twig:Checkbox id="demo-check-default" name="accept" />
        <twig:Label for="demo-check-checked">Checked</twig:Label>
        <twig:Checkbox id="demo-check-checked" name="accept_checked" checked />
        <twig:Label for="demo-check-disabled">Disabled</twig:Label>
        <twig:Checkbox id="demo-check-disabled" name="accept_disabled" disabled />
    </div>
</section>

<section class="ux-blocks-catalog-section" id="role-scroll-area" data-catalog-role="scroll-area">
    <h2>Scroll area</h2>
    <twig:ScrollArea style="max-height:8rem;">
        {% for i in 1..12 %}
            <p>Scrollable line {{ i }}</p>
        {% endfor %}
    </twig:ScrollArea>
</section>

<section class="ux-blocks-catalog-section" id="role-aspect-ratio" data-catalog-role="aspect-ratio">
    <h2>Aspect ratio</h2>
    <twig:AspectRatio ratio="16/9">
        <div style="display:flex;align-items:center;justify-content:center;background:var(--ui-color-surface-elevated, #eee);height:100%;">16:9</div>
    </twig:AspectRatio>
</section>

<section class="ux-blocks-catalog-section" id="role-divider" data-catalog-role="divider">
    <h2>Divider</h2>
    <p>Above</p>
    <twig:Divider />
    <p>Below</p>
    <div style="display:flex;align-items:center;min-height:3rem;">
        <span>Left</span>
        <twig:Divider variant="vertical" />
        <span>Right</span>
    </div>
</section>

<section class="ux-blocks-catalog-section" id="role-link" data-catalog-role="link">
    <h2>Link</h2>
    <twig:Link href="#role-link">Default link</twig:Link>
    <twig:Link href="#role-link" variant="muted">Muted link</twig:Link>
</section>

<section class="ux-blocks-catalog-section" id="role-switch" data-catalog-role="switch">
    <h2>Switch</h2>
    <twig:Label for="catalog-switch">Notifications</twig:Label>
    <twig:Switch id="catalog-switch" name="notifications" checked />
</section>

<section class="ux-blocks-catalog-section" id="role-file-input" data-catalog-role="file-input">
    <h2>File input</h2>
    <twig:FileInput name="upload" />
</section>

<section class="ux-blocks-catalog-section" id="role-skeleton" data-catalog-role="skeleton">
    <h2>Skeleton</h2>
    <twig:Skeleton style="width:12rem;height:1rem;" />
    <twig:Skeleton style="width:8rem;height:1rem;margin-top:0.5rem;" />
</section>

<section class="ux-blocks-catalog-section" id="role-progress" data-catalog-role="progress">
    <h2>Progress</h2>
    <twig:Progress value="60" max="100" />
</section>

<section class="ux-blocks-catalog-section" id="role-spinner" data-catalog-role="spinner">
    <h2>Spinner</h2>
    <twig:Spinner size="md" density="inline" aria-label="Loading" />
    <twig:Spinner size="sm" density="inline" />
</section>

<section class="ux-blocks-catalog-section" id="role-badge" data-catalog-role="badge">
    <h2>Badge</h2>
    <twig:Badge>New</twig:Badge>
    <twig:Badge variant="secondary">Beta</twig:Badge>
</section>

<section class="ux-blocks-catalog-section" id="role-avatar" data-catalog-role="avatar">
    <h2>Avatar</h2>
    <twig:Avatar>SF</twig:Avatar>
</section>

<section class="ux-blocks-catalog-section" id="role-kbd" data-catalog-role="kbd">
    <h2>Kbd</h2>
    <twig:Kbd>Ctrl</twig:Kbd> + <twig:Kbd>K</twig:Kbd>
</section>

<section class="ux-blocks-catalog-section" id="role-image" data-catalog-role="image">
    <h2>Image</h2>
    <twig:Image src="/images/placeholder.svg" alt="Catalog placeholder" />
</section>

