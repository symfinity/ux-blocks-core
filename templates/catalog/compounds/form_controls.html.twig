{% if twig_name == 'Input' %}
    <twig:Input id="demo-input" name="email" placeholder="you@example.com" />
{% elseif twig_name == 'Textarea' %}
    <twig:Textarea id="demo-textarea" name="notes" placeholder="Notes"></twig:Textarea>
{% elseif twig_name == 'Select' %}
    <twig:Select id="demo-select" name="choice">
        <option value="a">Option A</option>
        <option value="b">Option B</option>
    </twig:Select>
{% elseif twig_name == 'Checkbox' %}
    <twig:Label for="demo-check-default">Default</twig:Label>
    <twig:Checkbox id="demo-check-default" name="accept" />
{% elseif twig_name == 'RadioGroup' %}
    <twig:RadioGroup name="demo-plan">
        <twig:RadioGroup:Item name="demo-plan" value="monthly" checked>Monthly billing</twig:RadioGroup:Item>
        <twig:RadioGroup:Item name="demo-plan" value="annual">Annual billing</twig:RadioGroup:Item>
    </twig:RadioGroup>
{% elseif twig_name == 'Switch' %}
    <twig:Label for="catalog-switch">Notifications</twig:Label>
    <twig:Switch id="catalog-switch" name="notifications" checked />
{% elseif twig_name == 'FileInput' %}
    <twig:FileInput id="catalog-file" name="upload" />
{% else %}
    {% include '@UxBlocksCore/catalog/_render_component.html.twig' with {
        twig_name: twig_name,
        props: item.props|default({}),
        has_slot: item.has_slot|default(false),
        slot_text: item.slot_text|default(twig_name),
    } only %}
{% endif %}
