{% set gap = item.props.gap|default('md') %}
{% set variant = item.props.variant|default('default') %}
<twig:List gap="{{ gap }}" variant="{{ variant }}">
    <twig:List:Item>
        <twig:List:Item:Title>First item</twig:List:Item:Title>
        <twig:List:Item:Description>Supporting detail for the first row.</twig:List:Item:Description>
    </twig:List:Item>
    <twig:List:Item>
        <twig:List:Item:Title>Second item</twig:List:Item:Title>
        <twig:List:Item:Description>Supporting detail for the second row.</twig:List:Item:Description>
    </twig:List:Item>
    <twig:List:Item>
        <twig:List:Item:Title>Third item</twig:List:Item:Title>
        <twig:List:Item:Description>Supporting detail for the third row.</twig:List:Item:Description>
    </twig:List:Item>
</twig:List>
