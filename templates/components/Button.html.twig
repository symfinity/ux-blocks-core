<{{ as }}
    data-ui-role="button"
    data-ui-fragment="blocks.button"
    data-ui-variant="{{ variant }}"
    data-ui-appearance="{{ appearance }}"
    data-ui-size="{{ size }}"
    {% if 'a' == as %}href="{{ href }}"{% endif %}
    {% if block %}data-ui-layout="block"{% endif %}
    {% if disabled %}disabled data-ui-state="disabled"{% endif %}
    {{ attributes }}
>
    {% block content %}{% endblock %}
</{{ as }}>
