{% set caption_content -%}
    {%- block caption %}{%- endblock %}
{%- endset %}
<figure
    {% if align != 'none' %}data-ui-align="{{ align }}"{% endif %}
    {{ attributes }}
>
    {% block media %}{% endblock %}
    {% if caption_content|trim is not empty %}
        <figcaption data-ui-role="figure-caption">
            {{ caption_content|raw }}
        </figcaption>
    {% endif %}
</figure>
