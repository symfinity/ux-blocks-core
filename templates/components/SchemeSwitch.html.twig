{% set option_labels = {
    auto: 'System',
    light: 'Light',
    dark: 'Dark',
} %}

{% if enhanced %}
    {% set selectAttributes = attributes.defaults(
        stimulus_controller('@symfinity/ux-blocks-core/scheme-switch', {
            scheme: scheme,
            endpoint: schemeEndpoint,
        })|stimulus_action('@symfinity/ux-blocks-core/scheme-switch', 'update', 'change')
    ).defaults({ name: 'scheme' }) %}
{% else %}
    {% set selectAttributes = attributes.defaults({
        name: 'scheme',
        onchange: "(function (el) { var option = el.selectedOptions[0]; if (option && option.dataset.url) { window.location.href = option.dataset.url; } })(this)",
    }) %}
{% endif %}

{% embed '@UxBlocksCore/components/Select.html.twig' with {
    label: label,
    size: size,
    invalid: invalid,
    disabled: disabled,
    placeholder: null,
    attributes: selectAttributes,
} %}
    {% block content %}
        {% for link in links %}
            <option
                value="{{ link.scheme }}"
                data-url="{{ link.url }}"
                {% if link.active %}selected{% endif %}
            >{{ option_labels[link.scheme]|default(link.scheme) }}</option>
        {% endfor %}
    {% endblock %}
{% endembed %}
